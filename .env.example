# ── TraiNex Credentials (required) ──────────────────────────────────────────
# Set these as GitHub Secrets: TRAINEX_USER and TRAINEX_PASS
TRAINEX_USER=mark.schmidts
TRAINEX_PASS=your_password_here

# ── Optional: SMTP Email (leave empty to use GitHub Issues only) ─────────────
# If not set, notifications will be sent as GitHub Issue comments instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=mark.schmidts@student.medicalschool-hamburg.de

# ── Dashboard port ───────────────────────────────────────────────────────────
PORT=3000
