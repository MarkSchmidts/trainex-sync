# ── TraiNex Credentials (required) ──────────────────────────────────────────
# Set these as GitHub Secrets: TRAINEX_USER and TRAINEX_PASS
TRAINEX_USER=mark.schmidts
TRAINEX_PASS=your_password_here

# ── Optional: SMTP Email (leave empty to use GitHub Issues only) ─────────────
# If not set, notifications will be sent as GitHub Issue comments instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=mark.schmidts@student.medicalschool-hamburg.de

# ── Google OAuth (for Google Calendar sync) ──────────────────────────────────
# Set as GitHub Secrets: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
# The Client ID is also entered by users in the dashboard UI (localStorage)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# ── Dashboard port ───────────────────────────────────────────────────────────
PORT=3000
